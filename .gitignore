# ---------------------------------------------------------------------------
# Python bytecode
# ---------------------------------------------------------------------------
# Single recursive rule covers every __pycache__/ anywhere in the tree.
# Replaces the old per-package entries (/importer/__pycache__, etc.) that had
# to be added one-by-one as new packages landed.
**/__pycache__/

# ---------------------------------------------------------------------------
# Terraform working-directory artefacts
# ---------------------------------------------------------------------------
/.terraform
# Per-project Terraform working directories under imported/<project_id>/
# each get their own .terraform/ (provider binaries, ~hundreds of MB) on
# `terraform init`. None of it should be committed -- it's regenerated by
# init from the canonical provider_versions/.terraform.lock.hcl.
**/.terraform/
terraform.tfstate
*.backup

# Lock files: a single canonical lock at provider_versions/.terraform.lock.hcl
# is committed (HashiCorp guidance: pin provider versions/SHA-256 hashes for
# reproducible builds across dev box, CI, vendor demo, and Cloud Run).
# Per-project lock files under imported/<project_id>/.terraform.lock.hcl are
# SEEDED from the canonical one by terraform_client.init() and are NOT
# committed -- they would only ever be valid for the developer's own POC
# project_ids and are noise (worse: misleading) in a SaaS context where
# clients bring arbitrary project_ids. See common.workdir.seed_lock_file.
imported/*/.terraform.lock.hcl
imported/*/*/.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Generated / regeneratable artefacts
# ---------------------------------------------------------------------------
# HCL files are all machine-generated (by importer or translator). The source
# of truth is the cloud, not git. .tf files land in per-project workdirs
# which are themselves ephemeral (imported/<project_id>/ locally,
# /tmp/imported/<tenant>/<project>/ on Cloud Run).
*.tf

# CC-9 P4-9 exception: importer/golden_examples/*.tf are HAND-WRITTEN
# few-shot reference examples, source-controlled deliberately. The
# few-shot loader (importer/golden_examples_loader.py) reads them at
# runtime to inject into the LLM system prompt.
!importer/golden_examples/*.tf

# D-6 (2026-04-28) exception: provider_versions/_providers_seed.tf is
# the canonical providers stub copied into every fresh per-project
# workdir alongside .terraform.lock.hcl. Without it source-controlled,
# fresh checkouts regress to the no-provider-download failure mode
# that breaks LLM HCL generation. See common/workdir.seed_providers_stub
# and the file's own header for the rationale.
!provider_versions/_providers_seed.tf

# Generated by importer/schema_oracle.py via `terraform providers schema -json`.
# Large (~30 MB), regeneratable on demand, and pinned to the locally-installed
# provider versions — should not be source-controlled.
.terraform_schema_cache.json

# Importer KB is rebuilt from provider schemas on cache miss.
/importer/knowledge_base

# Translator diagnostic artifacts. Written by translator/yaml_engine.py to make
# stage-1 (YAML extraction) vs stage-2 (HCL generation) bug attribution possible.
# Regenerated on every translation run; never source-controlled.
_intermediate_blueprint_*.yaml

# ---------------------------------------------------------------------------
# Pre-refactor backups / local-only tooling
# ---------------------------------------------------------------------------
# Migration script archives go here (see scripts/migrate_workdir.py). Keeps
# rollback material on the developer's disk without polluting git history.
archive/

# Local Claude Code settings (per-developer).
.claude/settings.local.json
